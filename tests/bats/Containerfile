# Containerfile - Hermetic environment for bootstrap.sh integration tests
#
# Build and run with podman (preferred) or docker:
#   podman build -t plsec-test -f tests/bats/Containerfile .
#   podman run --rm plsec-test tests/bats/integration/
#
# Or use tests/bats/run-in-container.sh for auto-detection.

FROM ubuntu:24.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    bats \
    git \
    python3 \
    python3-yaml \
    curl \
    ca-certificates \
    wget \
    apt-transport-https \
    gnupg \
    lsb-release \
    && wget -qO - https://aquasecurity.github.io/trivy-repo/deb/public.key | gpg --dearmor | tee /usr/share/keyrings/trivy.gpg > /dev/null \
    && echo "deb [signed-by=/usr/share/keyrings/trivy.gpg] https://aquasecurity.github.io/trivy-repo/deb $(lsb_release -sc) main" | tee -a /etc/apt/sources.list.d/trivy.list \
    && apt-get update \
    && apt-get install -y trivy \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user for realistic HOME testing
RUN useradd -m -s /bin/bash testuser

WORKDIR /workspace

# Copy project files
COPY build/bootstrap.sh /workspace/build/bootstrap.sh
COPY bin/bootstrap.default.sh /workspace/bin/bootstrap.default.sh
COPY tests/bats/ /workspace/tests/bats/

# Ensure bootstrap is executable
RUN chmod +x /workspace/build/bootstrap.sh /workspace/bin/bootstrap.default.sh

USER testuser

ENTRYPOINT ["bats"]
CMD ["tests/bats/"]
