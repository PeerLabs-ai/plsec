# plsec.yaml - Security configuration
# Generated by plsec init

version: 1

project:
  name: {project_name}
  type: {project_type}

agent:
  type: {agent_type}
  config_path: ./CLAUDE.md

layers:
  static:
    enabled: true
    scanners:
      - trivy-secrets
      - trivy-misconfig
      - bandit
      - semgrep

  isolation:
    enabled: {isolation_enabled}
    runtime: podman

  proxy:
    enabled: {proxy_enabled}
    binary: pipelock
    mode: {proxy_mode}
    config: ./pipelock.yaml

  audit:
    enabled: true
    log_dir: ~/.peerlabs/plsec/logs
    integrity: {integrity_enabled}

credentials:
  storage: keychain
  keys: []
